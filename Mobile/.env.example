# Backend API base URL (must include /api/v1)
EXPO_PUBLIC_API_URL=.../api/v1

# Optional override for PayOS deep-link redirect prefix (must match BE MOBILE_* URLs).
# Default: Linking.createURL('payment') → mobile://payment
# EXPO_PUBLIC_MOBILE_PAYOS_REDIRECT_PREFIX=mobile://payment

# OCR.space API key for license plate scan in Expo Go (free at https://ocr.space/ocrapi)
# Without this, the shared "helloworld" key is rate-limited (HTTP 429).
EXPO_PUBLIC_OCR_SPACE_API_KEY=
