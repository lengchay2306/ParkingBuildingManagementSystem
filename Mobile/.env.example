# Backend API base URL (must include /api/v1)
EXPO_PUBLIC_API_URL=https://parkingbuildingmanagementsystem.onrender.com/api/v1

# FE web app (forgot/reset password pages)
EXPO_PUBLIC_WEB_APP_URL=https://parking-building-management-system-phi.vercel.app

# Optional. Prefix of BE MOBILE_RETURN_URL / MOBILE_CANCEL_URL
# BE uses three slashes: mobile:///payment/return
# EXPO_PUBLIC_MOBILE_PAYOS_REDIRECT_PREFIX=mobile:///payment

# OCR.space API key for license plate scan in Expo Go (free at https://ocr.space/ocrapi)
# Without this, the shared "helloworld" key is rate-limited (HTTP 429).
EXPO_PUBLIC_OCR_SPACE_API_KEY=
