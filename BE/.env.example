PORT=3000
MONGODB_URI=
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
FRONTEND_URL=http://localhost:8080
REDIS_URL=

# Google Gemini — chatbot (never commit real key to git)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# PayOS redirect URLs
FE_RETURN_URL=https://your-fe-domain/payment/return
FE_CANCEL_URL=https://your-fe-domain/payment/cancel
# Must match Mobile app.json "scheme" (default: mobile)
# Use three slashes: mobile:///payment/... so path is /payment/... (not host=payment)
MOBILE_RETURN_URL=mobile:///payment/return
MOBILE_CANCEL_URL=mobile:///payment/cancel
